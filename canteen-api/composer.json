{
  "name": "laravel/laravel",
  "type": "project",
  "description": "BVRIT Canteen API - Laravel Backend",
  "keywords": ["laravel", "api", "canteen", "ordering"],
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "laravel/framework": "11.48",
    "laravel/tinker": "^2.8",
    "tymon/jwt-auth": "^2.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

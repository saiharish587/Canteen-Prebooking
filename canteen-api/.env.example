APP_NAME="BVRIT Canteen API"
APP_ENV=production
APP_KEY=base64:changeme
APP_DEBUG=false
APP_URL=http://localhost

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bvrit_canteen
DB_USERNAME=root
DB_PASSWORD=

# For remote database with SSL (e.g., AWS RDS)
# MYSQL_ATTR_SSL_CA=/path/to/ca-bundle.crt

# JWT Configuration
JWT_SECRET=changeme
JWT_ALGORITHM=HS256
JWT_TTL=60

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@bvritcanteen.local
MAIL_FROM_NAME="BVRIT Canteen"

# Cache Configuration
CACHE_DRIVER=file

# Queue Configuration
QUEUE_CONNECTION=sync

# Session Configuration
SESSION_DRIVER=cookie

# Application Settings
APP_TIMEZONE=UTC
